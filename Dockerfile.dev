# Development Dockerfile for PRD Helper
# Multi-stage build for development environment

FROM node:20-alpine AS development

WORKDIR /app

# Install dependencies for native modules
RUN apk add --no-cache python3 make g++ git

# Copy package files (root only - server doesn't need client dependencies)
COPY package*.json ./
COPY server/tsconfig.json ./server/tsconfig.json

# Install root dependencies (includes server dependencies)
RUN npm install

# Copy shared code (needed by server for shared types)
COPY shared ./shared

# Copy root TypeScript config
COPY tsconfig.json ./tsconfig.json

# Copy server code
COPY server ./server

# Expose ports
EXPOSE 3000

# Default command (can be overridden in docker-compose)
CMD ["npm", "run", "dev:server"]
