{
  "name": "fullstack-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch --clear-screen=false server/src/index.ts",
    "dev:client": "cd client && vite",
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc -p server/tsconfig.json",
    "build:client": "cd client && vite build",
    "start": "node dist/server/index.js",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "docker:setup": "./scripts/docker-setup.sh setup",
    "docker:start": "./scripts/docker-setup.sh start",
    "docker:stop": "./scripts/docker-setup.sh stop",
    "docker:restart": "./scripts/docker-setup.sh restart",
    "docker:logs": "./scripts/docker-setup.sh logs",
    "docker:status": "./scripts/docker-setup.sh status",
    "docker:reset": "./scripts/docker-setup.sh reset"
  },
  "dependencies": {
    "@google-cloud/secret-manager": "^6.1.1",
    "@google-cloud/storage": "^7.17.3",
    "@sentry/node": "^10.26.0",
    "@sentry/tracing": "^7.120.4",
    "@tanstack/react-query": "^5.90.5",
    "@trpc/client": "^11.7.0",
    "@trpc/react-query": "^11.7.0",
    "@trpc/server": "^11.0.0",
    "@types/compression": "^1.8.1",
    "@types/express-session": "^1.18.2",
    "@types/multer": "^2.0.0",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "bcryptjs": "^3.0.2",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.18.2",
    "firebase-admin": "^13.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "lru-cache": "^11.2.2",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.10",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.2",
    "remark-breaks": "^4.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.10.5",
    "@types/nodemailer": "^7.0.3",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "tsx": "^4.20.6",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vitest": "^1.1.0"
  }
}
