# Database
DATABASE_URL="postgresql://user:password@localhost:5432/prd_helper?schema=public"

# Server
PORT=3000
NODE_ENV="development"

# JWT Authentication
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# AI Integration (OpenRouter)
OPENROUTER_API_KEY="your-openrouter-api-key"
OPENROUTER_MODEL="google/gemini-2.5-flash" # or "openai/gpt-4o"

# Client URL (for CORS)
CLIENT_URL="http://localhost:5173"
# To allow multiple dev URLs, separate with commas:
# CLIENT_URL="http://localhost:5173,http://localhost:5174"

# Optional: OAuth Providers (for future implementation)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""
