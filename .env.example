# Database
# For Supabase PgBouncer: postgresql://user:password@host:6543/postgres?pgbouncer=true&sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/prd_helper?schema=public"

# Server
PORT=3000
NODE_ENV="development"

# JWT Authentication
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# AI Integration (OpenRouter)
OPENROUTER_API_KEY="your-openrouter-api-key"
OPENROUTER_MODEL="google/gemini-2.5-flash" # Main model for questions/documents
OPENROUTER_EXPLANATION_MODEL="google/gemini-flash-1.5" # Faster/cheaper model for explanations

# Client URL (for CORS)
CLIENT_URL="http://localhost:5173"
# To allow multiple dev URLs, separate with commas:
# CLIENT_URL="http://localhost:5173,http://localhost:5174"

# OAuth Providers
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3000/api/auth/google/callback"

# Optional: GitHub OAuth (for future implementation)
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""

# Google Cloud (for Secret Manager)
GOOGLE_CLOUD_PROJECT_ID="myresume-457817"

# Email Configuration
ADMIN_EMAIL="jsong@koreatous.com"

# Gmail Credentials (stored in Google Secret Manager)
# - GMAIL_USER: Gmail address for sending emails
# - GMAIL_APP_PASSWORD: Gmail App Password (16-character code)
# These are fetched from Secret Manager at runtime, not from .env

# Google Cloud Storage (for file uploads)
GCS_BUCKET_NAME="prd-helper-uploads"
GCP_PROJECT_ID="myresume-457817"
GOOGLE_APPLICATION_CREDENTIALS="path/to/service-account-key.json"
