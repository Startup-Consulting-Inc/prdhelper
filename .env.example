# Server
PORT=3000
NODE_ENV="development"

# Firebase Configuration (Backend - Firebase Admin SDK)
FIREBASE_PROJECT_ID="clearly-478614"
FIREBASE_ADMIN_SDK_KEY_PATH="./serviceAccountKey.json" # Path to service account key for local development
FIRESTORE_DATABASE_ID="clearly" # Named Firestore database (use "(default)" for default database)

# Firebase Configuration (Frontend - Client SDK)
# Get these values from Firebase Console > Project Settings > General > Your apps > Web app
# VITE_FIREBASE_API_KEY="your-firebase-api-key"
# VITE_FIREBASE_AUTH_DOMAIN="clearly-478614.firebaseapp.com"
# VITE_FIREBASE_PROJECT_ID="clearly-478614"
# VITE_FIREBASE_STORAGE_BUCKET="clearly-478614.appspot.com"
# VITE_FIREBASE_MESSAGING_SENDER_ID="your-messaging-sender-id"
# VITE_FIREBASE_APP_ID="your-app-id"

# Firebase Auth Emulator (optional for local testing)
# VITE_FIREBASE_AUTH_EMULATOR_HOST="localhost:9099"

# AI Integration (OpenRouter)
OPENROUTER_API_KEY="your-openrouter-api-key"
OPENROUTER_MODEL="google/gemini-2.5-flash" # Main model for questions/documents
OPENROUTER_EXPLANATION_MODEL="google/gemini-flash-1.5" # Faster/cheaper model for explanations

# Client URL (for CORS)
CLIENT_URL="http://localhost:5173"
# To allow multiple dev URLs, separate with commas:
# CLIENT_URL="http://localhost:5173,http://localhost:5174"

# OAuth Providers
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3000/api/auth/google/callback"

# Optional: GitHub OAuth (for future implementation)
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""

# Google Cloud (for Secret Manager and Cloud Storage)
GOOGLE_CLOUD_PROJECT_ID="clearly-478614"

# Email Configuration
ADMIN_EMAIL="jsong@koreatous.com"

# Gmail Credentials (stored in Google Secret Manager)
# - GMAIL_USER: Gmail address for sending emails
# - GMAIL_APP_PASSWORD: Gmail App Password (16-character code)
# These are fetched from Secret Manager at runtime, not from .env

# Google Cloud Storage (for file uploads)
GCS_BUCKET_NAME="clearly-uploads"
GCP_PROJECT_ID="clearly-478614"
# GOOGLE_APPLICATION_CREDENTIALS is not needed - Firebase Admin SDK handles authentication

# Logging & Monitoring
# LOG_LEVEL: trace, debug, info, warn, error, fatal
# Default: debug in development, info in production
LOG_LEVEL="info"

# Error Tracking (optional but recommended for production)
# Backend Sentry DSN - for server-side error tracking
# Only active in production environment
# SENTRY_DSN="https://backend-dsn@sentry.io/backend-project-id"

# Frontend Sentry DSN - for client-side error tracking
# Only active in production builds (vite build)
# VITE_SENTRY_DSN="https://frontend-dsn@sentry.io/frontend-project-id"
